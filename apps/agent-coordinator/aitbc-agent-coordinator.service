[Unit]
Description=AITBC Agent Coordinator Service
After=network.target redis.service aitbc-blockchain-node.service
Wants=aitbc-blockchain-node.service

[Service]
Type=simple
User=aitbc-internal
Group=aitbc-services
WorkingDirectory=/opt/aitbc
Environment=PATH=/usr/bin:/usr/local/bin:/usr/bin:/bin
Environment=PYTHONPATH=/opt/aitbc:/opt/aitbc/apps/agent-coordinator/src
EnvironmentFile=/etc/aitbc/blockchain.env
EnvironmentFile=/etc/aitbc/node.env
EnvironmentFile=/etc/aitbc/blockchain-secrets.env

# Agent coordinator execution
ExecStart=/opt/aitbc/venv/bin/python -m app.main
ExecReload=/bin/kill -HUP $MAINPID
KillMode=mixed
TimeoutStopSec=10

# Production reliability
Restart=always
RestartSec=5

# Production logging
StandardOutput=journal
StandardError=journal
SyslogIdentifier=aitbc-agent-coordinator

# Production security
NoNewPrivileges=true

# Production performance
LimitNOFILE=65536
LimitNPROC=4096
MemoryMax=256M
CPUQuota=50%

[Install]
WantedBy=multi-user.target
