[Unit]
Description=AITBC Autonomous Agent Listener Daemon
Documentation=https://github.com/aitbc/blockchain
After=network.target aitbc-blockchain-node.service aitbc-agent-coordinator.service aitbc-hermes.service
Requires=aitbc-blockchain-node.service
Wants=aitbc-agent-coordinator.service aitbc-hermes.service

[Service]
Type=simple
User=root
Group=root
WorkingDirectory=/opt/aitbc
EnvironmentFile=/etc/aitbc/blockchain.env
Environment="PATH=/opt/aitbc/venv/bin:/usr/local/bin:/usr/bin:/bin"
Environment="PYTHONPATH=/opt/aitbc:/opt/aitbc/apps/blockchain-node/src"
Environment="HERMES_COORDINATOR_URL=http://localhost:8107"
Environment="HERMES_SERVICE_URL=http://localhost:8103"
Environment="ENABLE_HERMES_POLLING=true"
Environment="HERMES_AGENT_IDS=owl-hub"
Environment="AGENT_DAEMON_CHAINS=ait-hub.aitbc.bubuit.net"
ExecStart=/opt/aitbc/venv/bin/python /opt/aitbc/apps/agent-coordinator/scripts/agent_daemon.py --wallet my-agent-wallet --address "" --password-file /var/lib/aitbc/keystore/.genesis_password --keystore-dir /var/lib/aitbc/keystore --db-path /var/lib/aitbc/data/ait-hub.aitbc.bubuit.net/chain.db --rpc-url http://localhost:8202 --poll-interval 10 --reply-message pong --trigger-message ping --chain-id ait-hub.aitbc.bubuit.net

Restart=always
RestartSec=10
StandardOutput=journal
StandardError=journal
SyslogIdentifier=AgentDaemon

# Security settings
NoNewPrivileges=true
PrivateTmp=true
ProtectHome=true

[Install]
WantedBy=multi-user.target
