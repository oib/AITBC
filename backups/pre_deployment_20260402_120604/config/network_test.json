{
    "network_name": "network-test",
    "discovery": {
        "bootstrap_nodes": [
            "10.1.223.93:8000",
            "10.1.223.40:8000",
            "10.1.223.93:8001"
        ],
        "discovery_interval": 30,
        "peer_timeout": 300,
        "max_peers": 50
    },
    "health_monitoring": {
        "check_interval": 60,
        "max_latency_ms": 1000,
        "min_availability_percent": 90.0,
        "min_health_score": 0.5,
        "max_consecutive_failures": 3
    },
    "peer_management": {
        "max_connections": 50,
        "min_connections": 8,
        "connection_retry_interval": 300,
        "ban_threshold": 0.1,
        "auto_reconnect": true,
        "auto_ban_malicious": true,
        "load_balance": true
    },
    "topology": {
        "strategy": "hybrid",
        "optimization_interval": 300,
        "max_degree": 8,
        "min_degree": 3
    },
    "partition_handling": {
        "detection_interval": 30,
        "recovery_timeout": 300,
        "max_partition_size": 0.4,
        "min_connected_nodes": 3,
        "partition_detection_threshold": 0.3
    },
    "recovery": {
        "strategy": "adaptive",
        "recovery_interval": 60,
        "max_recovery_attempts": 3,
        "recovery_timeout": 300,
        "emergency_threshold": 0.1
    }
}
