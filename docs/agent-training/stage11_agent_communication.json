          "coordinator_url": "http://localhost:9001",
          "message_type": "broadcast",
          "payload": {"announcement": "test_announcement"},
          "priority": "normal",
          "agent_type": "worker"
        },
        "expected_result": {
          "status": "success",
          "count": ">0"
        },
        "success_criteria": {
          "status": "success",
          "response_fields": ["recipients", "count", "broadcast_at"]
        }
      },
      {
