## Verification Checklist (Run Before Tag)

Run these commands to verify each item before releasing:

```bash
# P0.1: Dead code removed
[ ! -d /opt/aitbc/cli/src ] && [ ! -d /opt/aitbc/cli/handlers ] && \
[ ! -d /opt/aitbc/cli/cleanup ] && [ ! -d /opt/aitbc/cli/variants ] && \
[ ! -f /opt/aitbc/cli/click_cli.py ] && [ ! -f /opt/aitbc/cli/enterprise_cli.py ] && \
[ ! -f /opt/aitbc/cli/genesis_cli.py ] && echo "OK" || echo "FAIL"

# P0.2: No disabled commands
! grep -q "Disabled" /opt/aitbc/cli/aitbc_cli/core/main.py && echo "OK" || echo "FAIL"

# P0.3: No root artifacts
[ ! -f /opt/aitbc/marketplace.db ] && [ ! -f /opt/aitbc/create_sample_offers.py ] && \
[ ! -f /opt/aitbc/create_sample_offers_simple.py ] && [ ! -f /opt/aitbc/pyproject.toml.new ] && \
echo "OK" || echo "FAIL"

# P0.4: No missing env files
for svc in /etc/systemd/system/aitbc-*.service; do
  name=$(basename $svc .service)
  grep -q "EnvironmentFile=.*%N" $svc 2>/dev/null && \
    [ ! -f /etc/aitbc/$name.env ] && echo "MISSING: $name.env"
done

# P1.5: Count 0.0.0.0 bindings
grep -rn "0.0.0.0" /opt/aitbc/apps/*/src --include="*.py" 2>/dev/null | \
  grep -i "uvicorn.run\|app.run\|host=" | wc -l

# P1.7: No hardcoded absolute URLs
grep -q "http://hub.aitbc.bubuit.net" /opt/aitbc/website/*.js 2>/dev/null && \
  echo "FAIL" || echo "OK"

# P1.8: mutants gitignored
git -C /opt/aitbc check-ignore /opt/aitbc/mutants/ >/dev/null 2>&1 && echo "OK" || echo "FAIL"

# CLI works
aitbc --help >/dev/null 2>&1 && echo "CLI OK" || echo "CLI FAIL"
```

