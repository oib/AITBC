# AITBC Blockchain Configuration Template
# Copy to /etc/aitbc/blockchain.env and customize
#
# ==========================================
# Variable Casing Convention
# ==========================================
# Use UPPER_SNAKE_CASE for all variables (systemd EnvironmentFile= passes exact casing)
# Wrapper script checks UPPERCASE first, then lowercase fallback for compatibility
# Example: RPC_BIND_HOST=0.0.0.0  (not rpc_bind_host)
#
# ==========================================
# Chain Identity
# ==========================================
CHAIN_ID=ait-testnet

# ==========================================
# RPC Configuration (API Server)
# ==========================================
# Bind to 0.0.0.0 for external access, 127.0.0.1 for localhost only
RPC_BIND_HOST=0.0.0.0
RPC_BIND_PORT=8202

# ==========================================
# P2P Configuration (Block Sync & Gossip)
# ==========================================
P2P_BIND_HOST=0.0.0.0
P2P_BIND_PORT=8200

# ==========================================
# Block Production (Proposer Nodes Only)
# ==========================================
# Set to true on proposer/authority nodes, false on follower nodes
ENABLE_BLOCK_PRODUCTION=false
BLOCK_TIME_SECONDS=6

# ==========================================
# Proposer Identity (PoA)
# ==========================================
# Unique proposer address for block signing (Ethereum-style 0x address)
# Generate with: python -c "from eth_account import Account; print(Account.create().address)"
PROPOSER_ID=0x<unique-proposer-address>

# ==========================================
# Network Peers
# ==========================================
# Comma-separated list of P2P peers for initial sync
# Format: hostname:port (e.g., "aitbc1:8200,aitbc2:8200")
P2P_PEERS=auto

# ==========================================
# Sync Configuration
# ==========================================
# Force full sync on startup (use for recovery)
# FORCE_SYNC=false

# ==========================================
# Subscription System (Agent Discovery)
# ==========================================
SUBSCRIPTION_ENABLED=true

# ==========================================
# Authentication (Bug 14 — dev-only header trust)
# ==========================================
# TRUST_X_WALLET_ADDRESS accepts the X-Wallet-Address HTTP header as the
# authenticated identity WITHOUT cryptographic verification. This is a
# development-only mode — NEVER enable in production. Default: false
# TRUST_X_WALLET_ADDRESS=false

# ==========================================
# Strict Imports (Bug 10 — fail-fast on missing modules)
# ==========================================
# When true, the node refuses to start if any core RPC module (disputes,
# contracts, islands, bridge, staking, GPU resources) fails to import.
# Recommended for production. Default: false
# STRICT_IMPORTS=false

# ==========================================
# Bridge Security (v0.7.2 + Audit Fixes)
# ==========================================
# When true, bridge _validate_proof REJECTS any proof that omits a Merkle
# inclusion proof (merkle_proof + lock_event). Set to true for production
# networks that move real value. Default: false (dev/isolated networks)
BRIDGE_REQUIRE_MERKLE_PROOF=true

# Bridge release path — enables confirm_transfer fund release.
# Default: true (verification is now hardened with validator-set membership
# checks and Merkle proof enforcement)
# BRIDGE_RELEASE_ENABLED=true

# Multi-sig threshold verification for bridge proofs.
# When true, requires M-of-N validator signatures instead of single-signer.
# Default: false (single-signer mode with validator-set membership check)
# BRIDGE_MULTISIG_ENABLED=false
