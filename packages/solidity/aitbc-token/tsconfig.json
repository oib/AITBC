{
  "compilerOptions": {
    "target": "es2022",
    "module": "esnext",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "outDir": "dist",
    "resolveJsonModule": true,
    "moduleResolution": "bundler"
  },
  "include": [
    "hardhat.config.ts",
    "hardhat-toolbox-mocha-ethers.d.ts",
    "scripts",
    "test",
    "typechain-types"
  ],
  "exclude": ["dist"]
}
